generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RecordType {
  income
  expense
}

model FinancialRecord {
  id          String     @id @default(cuid())
  amount      Decimal    @db.Decimal(12, 2)
  type        RecordType
  category    String
  recordDate  DateTime
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([recordDate])
  @@index([type])
  @@index([category])
}
